# MongoDB Atlas URI — append /blog before the ?
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/blog?retryWrites=true&w=majority

# JWT — generate: openssl rand -hex 48
JWT_SECRET=replace-with-long-random-string

# Admin credentials (used by seed script)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-strong-password

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (email newsletters) — get API key at resend.com
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_DOMAIN=yourdomain.com

# Public site URL (no trailing slash). Used in sitemap, RSS, OG metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
